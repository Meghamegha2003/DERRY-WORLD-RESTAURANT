    <title>Derry World - Cart</title>

    <!-- Bootstrap core CSS -->
    <link rel="stylesheet" href="css/bootstrap.css" />

    <!-- Font Awesome -->
    <link href="css/font-awesome.min.css" rel="stylesheet" />

    <!-- Custom Styles -->
    <link href="css/style.css" rel="stylesheet" />
    <link href="css/responsive.css" rel="stylesheet" />
    <link
      href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@400;500;600;700&amp;family=Open+Sans:wght@400;600;700&amp;display=swap"
      rel="stylesheet"
    />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css"
      rel="stylesheet"
    />

    <style>
      .collapse {
        visibility: visible !important;
      }

      .user_link {
        text-decoration: none;
      }

      .cart_link svg {
        width: 17px;
        height: auto;
        fill: var(--white);
        margin-bottom: 2px;
      }

      /* Additional styling for other elements (same as before) */
      .header_section {
        padding: 10px 0;
        background-color: #333;
      }

      .navbar-brand span {
        font-family: "Dancing Script", cursive;
        font-weight: bold;
        font-size: 32px;
        color: #ffffff;
      }

      .navbar-nav .nav-link {
        color: #fff;
        padding: 5px 20px;
        text-align: center;
        text-transform: uppercase;
        border-radius: 5px;
        -webkit-transition: all 0.3s;
        transition: all 0.3s;
      }

      .navbar-nav .nav-link:hover {
        color: #ffc107;
      }

      .user_option {
        display: flex;
        align-items: center;
      }

      .user_link {
        color: #fff;
        font-weight: 600;
        margin-left: 15px;
        transition: color 0.3s;
      }

      .user_link:hover {
        color: #ffc107;
      }

      .cart_link {
        position: relative;
        display: inline-block;
        margin-left: 15px;
      }

      .cart-link svg {
        width: 20px;
        height: auto;
        fill: #fff;
      }

      .cart-count {
        position: absolute;
        top: -7px;
        right: -12px;
        background-color: #ffc107;
        color: white;
        font-size: 12px;
        font-weight: bold;
        border-radius: 50%;
        width: 20px;
        height: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 10;
      }

      .cart-count:hover {
        background-color: #ff5722;
      }

      .dropdown-menu {
        background-color: #333;
        border: none;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
      }

      .dropdown-item {
        color: #fff;
        font-weight: 600;
        transition: background-color 0.3s, color 0.3s;
      }

      .dropdown-item:hover {
        background-color: #ffc107;
        color: #333;
      }

      .navbar-toggler {
        border: none;
        background-color: #fff;
      }

      @media (max-width: 768px) {
        .navbar-nav {
          text-align: center;
          margin-top: 10px;
        }

        .navbar-nav .nav-link {
          margin: 10px 0;
        }

        .user_option {
          flex-direction: column;
          margin-top: 10px;
        }

        .cart-link {
          margin-left: 0;
        }
      }
      .product-name {
        font-size: 2.5rem;
        font-weight: bold;
        color: #333;
        margin-bottom: 1.5rem;
        font-family: 'Open Sans', sans-serif;
        line-height: 1.2;
        text-transform: capitalize;
      }

      .description-title,
      .category-title,
      .price-title,
      .rating-title {
        font-size: 1.2rem;
        font-weight: 600;
        color: #555;
        margin-bottom: 0.5rem;
      }

      .description-text {
        font-size: 1.1rem;
        color: #666;
        line-height: 1.6;
      }

      .category-badge {
        display: inline-block;
        padding: 0.5rem 1rem;
        background-color: #f8f9fa;
        border-radius: 20px;
        color: #555;
        font-weight: 500;
        font-size: 1rem;
      }

      .price-container {
        display: flex;
        align-items: center;
        gap: 1rem;
      }

      .sales-price {
        font-size: 1.8rem;
        font-weight: bold;
        color: #dc3545;
      }

      .regular-price {
        font-size: 1.4rem;
        color: #999;
        text-decoration: line-through;
      }

      .regular-price-only {
        font-size: 1.8rem;
        font-weight: bold;
        color: #28a745;
      }

      .stars {
        display: flex;
        align-items: center;
      }

      .stars .fa-star {
        font-size: 2rem;
        margin-right: 5px;
        transition: color 0.2s ease;
      }

      .stars .fa-star.text-warning {
        color: #ffc107 !important;
      }

      .stars .fa-star.text-muted {
        color: #dedede !important;
      }

      .footer_section {
        background-color: #333;
        color: white;
        padding: 50px 0;
      }

      .footer_section h5 {
        font-size: 18px;
        font-weight: bold;
        margin-bottom: 15px;
      }

      .footer_section p,
      .footer_section a {
        font-size: 14px;
      }

      .footer_section a {
        color: white;
        text-decoration: none;
        transition: color 0.3s;
      }

      .footer_section a:hover {
        color: #ffc107;
      }

      .social-icons i {
        font-size: 20px;
        margin-right: 10px;
        transition: color 0.3s;
      }

      .social-icons i:hover {
        color: #ffc107;
      }

      @media (max-width: 768px) {
        .footer_section .row {
          text-align: center;
        }

        .footer_section .col-md-4 {
          margin-bottom: 20px;
        }
      }
      .product-name {
        font-size: 2.5rem;
        font-weight: bold;
        color: #333;
        margin-bottom: 1.5rem;
        font-family: 'Open Sans', sans-serif;
        line-height: 1.2;
        text-transform: capitalize;
      }

      .description-title,
      .category-title,
      .price-title,
      .rating-title {
        font-size: 1.2rem;
        font-weight: 600;
        color: #555;
        margin-bottom: 0.5rem;
      }

      .description-text {
        font-size: 1.1rem;
        color: #666;
        line-height: 1.6;
      }

      .category-badge {
        display: inline-block;
        padding: 0.5rem 1rem;
        background-color: #f8f9fa;
        border-radius: 20px;
        color: #555;
        font-weight: 500;
        font-size: 1rem;
      }

      .price-container {
        display: flex;
        align-items: center;
        gap: 1rem;
      }

      .sales-price {
        font-size: 1.8rem;
        font-weight: bold;
        color: #dc3545;
      }

      .regular-price {
        font-size: 1.4rem;
        color: #999;
        text-decoration: line-through;
      }

      .regular-price-only {
        font-size: 1.8rem;
        font-weight: bold;
        color: #28a745;
      }

      .stars {
        display: flex;
        align-items: center;
      }

      .stars .fa-star {
        font-size: 2rem;
        margin-right: 5px;
        transition: color 0.2s ease;
      }

      .stars .fa-star.text-warning {
        color: #ffc107 !important;
      }

      .stars .fa-star.text-muted {
        color: #dedede !important;
      }

      .buttons-section .btn {
        padding: 0.75rem 1.5rem;
        font-size: 1.1rem;
        font-weight: 500;
        border-radius: 5px;
        transition: all 0.3s ease;
      }

      .buttons-section .btn-primary {
        background-color: #007bff;
        border-color: #007bff;
      }

      .buttons-section .btn-primary:hover {
        background-color: #0056b3;
        border-color: #0056b3;
      }

      .buttons-section .btn-success {
        background-color: #28a745;
        border-color: #28a745;
      }

      .buttons-section .btn-success:hover {
        background-color: #218838;
        border-color: #218838;
      }

      .buttons-section .btn-outline-secondary {
        color: #6c757d;
        border-color: #6c757d;
      }

      .buttons-section .btn-outline-secondary:hover {
        color: #fff;
        background-color: #6c757d;
        border-color: #6c757d;
      }

      @media (max-width: 768px) {
        .product-name {
          font-size: 2rem;
        }
        
        .sales-price,
        .regular-price-only {
          font-size: 1.5rem;
        }
        
        .regular-price {
          font-size: 1.2rem;
        }
        
        .buttons-section .btn {
          width: 100%;
          margin-bottom: 0.5rem;
        }
        
        .buttons-section .btn + .btn {
          margin-left: 0 !important;
        }
      }
    </style>
  </head>
  <body class="sub_page">
    <!-- Header (unchanged) -->
    <header class="header_section">
      <div class="container">
        <nav class="navbar navbar-expand-lg custom_nav-container">
          <a class="navbar-brand" href="/">
            <span>Derry World</span>
          </a>
          <button
            class="navbar-toggler"
            type="button"
            data-toggle="collapse"
            data-target="#navbarSupportedContent"
          >
            <span class="navbar-toggler-icon"></span>
          </button>

          <div class="collapse navbar-collapse" id="navbarSupportedContent">
            <ul class="navbar-nav mx-auto">
              <li class="nav-item">
                <a class="nav-link" href="/">Home</a>
              </li>
              <li class="nav-item active">
                <a class="nav-link" href="/menu">Menu</a>
              </li>
              <li class="nav-item">
                <a class="nav-link" href="/about">About</a>
              </li>
            </ul>
            <div class="user_option">
              <% if (user) { %>
              <!-- Dropdown for username -->
              <div class="dropdown">
                <a
                  class="user_link dropdown-toggle"
                  href="#"
                  id="dropdownMenuButton"
                  data-toggle="dropdown"
                  aria-haspopup="true"
                  aria-expanded="false"
                >
                  <i
                    class="fa fa-user"
                    aria-hidden="true"
                    style="color: #ffc107"
                  ></i>
                  <span style="color: white"><%= user.name %></span>
                </a>
                <div class="dropdown-menu" aria-labelledby="dropdownMenuButton">
                  <a class="dropdown-item" href="/profile">Profile</a>
                  <a class="dropdown-item" href="/order/{{orderId}}">Order</a>
                  <a class="dropdown-item" href="/logout">Logout</a>
                </div>
              </div>
              <% } else { %>
              <a class="user_link" href="/login">Login</a>
              <a class="user_link" href="/register">Register</a>
              <% } %>
              <a class="cart_link" href="/cart">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 456.029 456.029"
                  style="fill: #ffffff"
                >
                  <g>
                    <path
                      d="M345.6,338.862c-29.184,0-53.248,23.552-53.248,53.248c0,29.184,23.552,53.248,53.248,53.248c29.184,0,53.248-23.552,53.248-53.248C398.336,362.926,374.784,338.862,345.6,338.862z"
                    />
                    <path
                      d="M439.296,84.91c-1.024,0-2.56-0.512-4.096-0.512H112.64l-5.12-34.304C104.448,27.566,84.992,10.67,61.952,10.67H20.48C9.216,10.67,0,19.886,0,31.15c0,11.264,9.216,20.48,20.48,20.48h41.472l31.744,216.064c4.096,27.136,27.648,47.616,55.296,47.616h212.992c26.624,0,49.664-18.944,55.296-45.056l33.28-166.4C457.728,97.71,450.56,86.958,439.296,84.91z"
                    />
                    <path
                      d="M215.04,389.55c-1.024-28.16-24.576-50.688-52.736-50.688c-29.696,1.536-52.224,26.112-51.2,55.296c1.024,28.16,24.064,50.688,52.224,50.688h1.024C193.536,443.31,216.576,418.734,215.04,389.55z"
                    />
                  </g>
                </svg>

                <span class="cart-count"><%= cartCount %></span>
              </a>
            </div>
          </div>
        </nav>
      </div>
    </header>

    <!-- Main Content -->
    <section class="food-details py-5">
      <div class="container">
        <div class="row">
          <!-- Big Product Image with Zoom -->
          <div class="col-md-6 position-relative">
            <div class="image-container">
              <img
                id="mainImage"
                src="/<%= product.productImage[0] %>"
                alt="<%= product.name %>"
                onerror="this.src='/default-image.jpg'"
              />
            </div>
            <div class="zoom-box" id="zoomBox" style="display: none">
              <img
                id="zoomedImage"
                src="/<%= product.productImage[0] %>"
                alt="Zoomed Image"
              />
            </div>
            <div class="thumbnails-row d-flex justify-content-start mt-3 gap-2">
              <% product.productImage.forEach((img, index) => { %>
              <img
                src="/<%= img.replace(/\\/g, '/') %>"
                alt="Thumbnail <%= index + 1 %>"
                onclick="changeImage('/<%= img.replace(/\\/g, '/') %>')"
                onerror="this.src='/default-image.jpg'"
              />
              <% }); %>
            </div>
          </div>

          <!-- Product Details Section -->
          <div class="col-md-6">
            <h2 class="product-name mb-4"><%= product.name %></h2>
            
            <div class="product-description mb-4">
              <h4 class="description-title mb-2">Description</h4>
              <p class="description-text"><%= product.description %></p>
            </div>

            <div class="category-info mb-4">
              <h4 class="category-title mb-2">Category</h4>
              <span class="category-badge"><%= product.category.name %></span>
            </div>
          
            <!-- Price -->
            <div class="price-section mb-4">
              <h4 class="price-title mb-2">Price</h4>
              <% if (product.salesPrice < product.regularPrice) { %>
                <div class="price-container">
                  <span class="sales-price">₹<%= product.salesPrice %></span>
                  <span class="regular-price">₹<%= product.regularPrice %></span>
                </div>
              <% } else { %>
                <div class="price-container">
                  <span class="regular-price-only">₹<%= product.regularPrice %></span>
                </div>
              <% } %>
            </div>

            <!-- Ratings Section -->
            <div class="rating-section mb-4">
              <h4 class="rating-title mb-2">Rating</h4>
              <div class="stars">
                <% for (let i = 0; i < 5; i++) { %>
                  <i class="fa fa-star <%= i < Math.round(product.averageRating) ? 'text-warning' : 'text-muted' %>"></i>
                <% } %>
              </div>
            </div>

            <!-- Buttons Section -->
            <div class="buttons-section mt-4">
              <% if (product.quantity === 0) { %>
                <button class="btn btn-secondary" disabled>Out of Stock</button>
              <% } else { %>
                <% if (cartItems.includes(product._id.toString())) { %>
                  <a href="/cart" class="btn btn-success">Go to Cart</a>
                <% } else { %>
                  <button onclick="addToCart('<%= product._id %>')" class="btn btn-primary">Add to Cart</button>
                <% } %>
              <% } %>
              <button class="btn btn-outline-secondary ms-2" onclick="history.back()">Go Back</button>
            </div>
          </div>

        </div>
      </div>
    </section>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.5.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/OwlCarousel2/2.3.4/owl.carousel.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-nice-select/1.1.0/js/jquery.nice-select.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
      $(document).ready(function() {
        $(".owl-carousel").owlCarousel();
        $('select').niceSelect();
      });
    </script>

    <script>
      document.addEventListener("DOMContentLoaded", () => {
        const mainImage = document.getElementById("mainImage");
        const zoomBox = document.getElementById("zoomBox");
        const zoomedImage = document.getElementById("zoomedImage");

        // Adjust the zoomed image on mouse movement
        mainImage.addEventListener("mousemove", (event) => {
          const rect = mainImage.getBoundingClientRect();
          const x = event.clientX - rect.left;
          const y = event.clientY - rect.top;

          // Calculate the zoom position percentage
          const xPercent = (x / rect.width) * 100;
          const yPercent = (y / rect.height) * 100;

          // Show the zoom box and update zoomed image position
          zoomBox.style.display = "block";
          zoomedImage.style.transformOrigin = `${xPercent}% ${yPercent}%`;
          zoomedImage.style.transform = "scale(2)"; // Adjust the scale for zoom level
        });

        // Hide the zoom box when the mouse leaves the main image
        mainImage.addEventListener("mouseleave", () => {
          zoomBox.style.display = "none";
        });
      });

      function changeImage(src) {
        mainImage.src = src;
        zoomedImage.src = src;
      }
      
      function updateCartDisplay(cart) {
        const cartCount = cart.items.reduce(
          (total, item) => total + item.quantity,
          0
        );
        document.getElementById("cart-count").textContent = cartCount;
      }
    </script>

    <script>
      async function addToCart(productId) {
        try {
          const response = await fetch('/cart/add', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({ productId }),
          });
          
          const result = await response.json();
          
          // Update cart count regardless of success/failure
          const cartCountElement = document.querySelector('.cart-count');
          if (cartCountElement && result.cartCount) {
            cartCountElement.textContent = result.cartCount;
          }

          if (response.ok && result.success) {
            // Change the button to "Go to Cart"
            const addToCartBtn = document.querySelector('.buttons-section button.btn-primary');
            if (addToCartBtn) {
              const goToCartLink = document.createElement('a');
              goToCartLink.href = '/cart';
              goToCartLink.className = 'btn btn-success';
              goToCartLink.textContent = 'Go to Cart';
              addToCartBtn.replaceWith(goToCartLink);
            }

            // Show success message
            Swal.fire({
              icon: 'success',
              title: 'Success!',
              text: result.message,
              showConfirmButton: false,
              timer: 1500
            });
          } else {
            // If it's a quantity limit error
            if (response.status === 400 && result.message.includes('Maximum quantity limit')) {
              Swal.fire({
                icon: 'warning',
                title: 'Quantity Limit Reached',
                text: 'You can only add up to 5 quantities of this item.',
                showCancelButton: true,
                confirmButtonText: 'View Cart',
                cancelButtonText: 'Continue Shopping'
              }).then((result) => {
                if (result.isConfirmed) {
                  window.location.href = '/cart';
                }
              });
            } else {
              throw new Error(result.message || 'Failed to add product to cart');
            }
          }
        } catch (error) {
          console.error('Error adding to cart:', error);
          Swal.fire({
            icon: 'error',
            title: 'Oops...',
            text: error.message || 'Failed to add product to cart. Please try again.'
          });
        }
      }
    </script>
  </body>
</html>
