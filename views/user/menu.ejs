                      <div class="detail-box" style="
  background: white; 
  color: black; 
  padding: 15px; 
  border-radius: 10px; 
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1); 
  max-width: 400px; 
  margin: auto;">

  <h5 style="margin-bottom: 15px; font-size: 18px; font-weight: bold; text-align: center;">Filters</h5>

  <div class="filter_group" style="margin-bottom: 15px;">
    <label for="diet" style="display: block; margin-bottom: 5px; font-weight: bold;">Dietary Category</label>
    <select id="diet" style="
      width: 100%; 
      padding: 8px; 
      font-size: 14px; 
      border: 1px solid #ccc; 
      border-radius: 5px;">
     <option value="" disabled selected>Select a type</option>
     <option value="veg">Veg</option>
     <option value="non-veg">Non-Veg</option>
     <option value="vegan">Vegan</option>
    </select>
  </div>

  <div class="filter_group" style="margin-bottom: 15px;">
    <label for="price" style="display: block; margin-bottom: 5px; font-weight: bold;">Price Range</label>
    <div class="price_inputs" style="display: flex; gap: 10px;">
      <input type="number" placeholder="Min" id="price-min" style="
        flex: 1; 
        padding: 8px; 
        font-size: 14px; 
        border: 1px solid #ccc; 
        border-radius: 5px;">
      <input type="number" placeholder="Max" id="price-max" style="
        flex: 1; 
        padding: 8px; 
        font-size: 14px; 
        border: 1px solid #ccc; 
        border-radius: 5px;">
    </div>
  </div>

  <div class="filter_group" style="margin-bottom: 15px;">
    <label for="rating" style="display: block; margin-bottom: 5px; font-weight: bold;">Rating</label>
    <select id="rating" style="
      width: 100%; 
      padding: 8px; 
      font-size: 14px; 
      border: 1px solid #ccc; 
      border-radius: 5px;">
      <option value="all">All Ratings</option>
      <option value="4plus">4+ Stars</option>
      <option value="3plus">3+ Stars</option>
      <option value="2plus">2+ Stars</option>
      <option value="1plus">1+ Stars</option>
    </select>
  </div>

  <div class="filter_group" style="margin-bottom: 15px;">
    <label for="offers" style="display: block; margin-bottom: 5px; font-weight: bold;">Offers</label>
    <select id="offers" style="
      width: 100%; 
      padding: 8px; 
      font-size: 14px; 
      border: 1px solid #ccc; 
      border-radius: 5px;">
      <option value="all">All Offers</option>
      <option value="discount">Discount</option>
      <option value="combo">Combo Offers</option>
    </select>
  </div>

  <div class="apply_button" style="text-align: center;">
    <button type="submit" class="btn-apply" style="
      padding: 10px 20px; 
      font-size: 14px; 
      font-weight: bold; 
      color: white; 
      background-color: #ffbe33; 
      border: none; 
      border-radius: 5px; 
      cursor: pointer;">
      Apply Filters
    </button>
  </div>

