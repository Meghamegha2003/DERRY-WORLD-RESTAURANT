    <style>
      .filters_menu li.active {
        font-weight: bold;
        color: #ffbe33;
      }
      .cart-count {
        position: absolute;
        top: -8px;
        right: -8px;
        background-color: #ffbe33;
        color: white;
        border-radius: 50%;
        padding: 4px 8px;
        font-size: 12px;
