            </div>
          </nav>
        </div>
      </header>
      <!-- end header section -->
    </div>

    <!-- food section -->
    <section class="food_section layout_padding">
      <div class="container">
        <div class="heading_container heading_center">
          <h2>Our Menu</h2>
        </div>

        <ul class="filters_menu">
          <li class="<%= !selectedCategory ? 'active' : '' %>" 
              onclick="window.location.href='/menu'">
            All
          </li>
          <% categories.forEach((category) => { %>
            <li class="<%= selectedCategory === category.name ? 'active' : '' %>"
                onclick="window.location.href='/menu?category=<%= category.name %>'">
              <%= category.name %>
            </li>
          <% }); %>
        </ul>

        <div class="filters-content">
          <div class="row grid">
            <% products.forEach((product) => { %>
              <div class="col-sm-6 col-lg-4 all <%= product.category.name %>">
                <div class="box">
                  <div>
                    <div class="img-box">
                      <!-- Dynamically load the first product image -->
                      <img src="/<%= product.productImage[0] %>" alt="<%= product.name %>" />

                    </div>
                    <div class="detail-box">
                      <h5><%= product.name %></h5>
                      <p><%= product.description %></p>
                      <div class="options">
                        <!-- Dynamically display product price -->
                        <h6>$<%= product.salesPrice || product.regularPrice %></h6>
                        <a href="">
                          <svg
                            version="1.1"
                            id="Capa_1"
                            xmlns="http://www.w3.org/2000/svg"
                            xmlns:xlink="http://www.w3.org/1999/xlink"
