<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, shrink-to-fit=no"
    />
    <meta name="keywords" content="Derry World, Travel, Explore" />
    <meta
      name="description"
      content="Register to Derry World and start exploring today!"
    />
    <meta name="author" content="Derry World" />
    <link rel="shortcut icon" href="/images/favicon.png" type="image/png" />
    <title>Register - Derry World</title>
    <!-- Bootstrap CDN for better responsiveness -->
    <link
      rel="stylesheet"
      href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css"
    />
    <link rel="stylesheet" href="/css/style.css" />
    <link rel="stylesheet" href="/css/responsive.css" />
    <!-- SweetAlert CDN -->
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css"
    />
    <style>
      .login-container {
        background-color: #fff;
        color: #000;
        border-radius: 10px;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        padding: 30px;
        margin-top: 50px;
        margin-bottom: 50px;
      }

      .login-container h2 {
        color: #000;
        margin-bottom: 20px;
      }

      .login-container label {
        font-weight: bold;
      }

      .btn-login {
        background-color: #007bff;
        color: #fff;
        border: none;
        padding: 10px;
        border-radius: 5px;
        font-size: 16px;
        font-weight: bold;
        cursor: pointer;
        width: 100%;
      }

      .btn-login:hover {
        background-color: #0056b3;
      }

      .btn-google {
        background-color: #db4437;
        color: #fff;
        border: none;
        padding: 10px;
        border-radius: 5px;
        font-size: 16px;
        font-weight: bold;
        cursor: pointer;
        width: 100%;
      }

      .btn-google:hover {
        background-color: #a33627;
      }

      /* Media Query for smaller screens */
      @media (max-width: 767px) {
        .login-container {
          padding: 20px;
        }

        .btn-login,
        .btn-google {
          font-size: 14px;
          padding: 8px;
        }

        .container {
          padding-left: 15px;
          padding-right: 15px;
        }
      }
    </style>
  </head>
  <body>
    <div class="hero_area">
      <div class="bg-box">
        <img
          src="/images/hero-bg.jpg"
          alt="Background Image"
          class="img-fluid"
        />
      </div>
      <header class="header_section">
        <div class="container">
          <nav class="navbar navbar-expand-lg custom_nav-container">
            <a class="navbar-brand" href="/">
              <span>Derry World</span>
            </a>
          </nav>
        </div>
      </header>
      <div class="container">
        <div class="row justify-content-center">
          <div class="col-lg-6 col-md-8 col-sm-12">
            <div class="login-container">
              <h2 class="text-center">Register</h2>

              <form
                id="registerForm"
                action="/register"
                method="post"
                onsubmit="return validateRegisterForm(event)"
                novalidate
              >
                <div class="form-group">
                  <label for="username">Full Name</label>
                  <input
                    type="text"
                    class="form-control"
                    id="username"
                    name="name"
                    required
                  />
                </div>
                <div class="form-group">
                  <label for="email">Email</label>
                  <input
                    type="email"
                    class="form-control"
                    id="email"
                    name="email"
                    required
                  />
                </div>
                <div class="form-group">
                  <label for="phone">Phone Number</label>
                  <input
                    type="tel"
                    class="form-control"
                    id="phone"
                    name="phone"
                    required
                  />
                </div>
                <div class="form-group">
                  <label for="password">Password</label>
                  <input
                    type="password"
                    class="form-control"
                    id="password"
                    name="password"
                    required
                  />
                </div>
                <div class="form-group">
                  <label for="confirmPassword">Confirm Password</label>
                  <input
                    type="password"
                    class="form-control"
                    id="confirmPassword"
                    name="confirmPassword"
                    required
                  />
                </div>

                <button type="submit" class="btn btn-login mb-3">Register</button>
                <div class="text-center">
                  <p>Already have an account? <a href="/login">Login here</a></p>
                </div>
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
      async function validateRegisterForm(event) {
        event.preventDefault();
        
        const name = document.getElementById('username').value.trim();
        const email = document.getElementById('email').value.trim();
        const phone = document.getElementById('phone').value.trim();
        const password = document.getElementById('password').value;
        const confirmPassword = document.getElementById('confirmPassword').value;

        // Name validation
        if (!name || name.length < 3) {
          await Swal.fire({
            title: '<span style="font-size: 24px; font-weight: 600;">Invalid Name</span>',
            text: 'Please enter a valid name (at least 3 characters)',
            icon: 'error',
            confirmButtonColor: '#007bff'
          });
          return false;
        }

        // Email validation
        const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
        if (!email || !emailRegex.test(email)) {
          await Swal.fire({
            title: '<span style="font-size: 24px; font-weight: 600;">Invalid Email</span>',
            text: 'Please enter a valid email address',
            icon: 'error',
            confirmButtonColor: '#007bff'
          });
          return false;
        }

        // Phone validation
        const phoneRegex = /^[0-9]{10}$/;
        if (!phone || !phoneRegex.test(phone)) {
          await Swal.fire({
            title: '<span style="font-size: 24px; font-weight: 600;">Invalid Phone Number</span>',
            text: 'Please enter a valid 10-digit phone number',
            icon: 'error',
            confirmButtonColor: '#007bff'
          });
          return false;
        }

        // Password validation
        if (!password || password.length < 8) {
          await Swal.fire({
            title: '<span style="font-size: 24px; font-weight: 600;">Password Too Short</span>',
            text: 'Password must be at least 8 characters long',
            icon: 'error',
            confirmButtonColor: '#007bff'
          });
          return false;
        }

        const hasUpper = /[A-Z]/.test(password);
        const hasLower = /[a-z]/.test(password);
        const hasNumber = /[0-9]/.test(password);
        const hasSpecial = /[!@#$%^&*]/.test(password);

        if (!hasUpper || !hasLower || !hasNumber || !hasSpecial) {
          await Swal.fire({
            title: '<span style="font-size: 24px; font-weight: 600;">Password Requirements</span>',
            html: `
              <div style="text-align: left; padding: 20px; background: #f8f9fa; border-radius: 10px; margin: 15px 0;">
                <div style="font-size: 16px; color: ${hasUpper ? '#28a745' : '#dc3545'};">
                  ${hasUpper ? '✓' : '✗'} One uppercase letter
                </div>
                <div style="font-size: 16px; color: ${hasLower ? '#28a745' : '#dc3545'};">
                  ${hasLower ? '✓' : '✗'} One lowercase letter
                </div>
                <div style="font-size: 16px; color: ${hasNumber ? '#28a745' : '#dc3545'};">
                  ${hasNumber ? '✓' : '✗'} One number
                </div>
                <div style="font-size: 16px; color: ${hasSpecial ? '#28a745' : '#dc3545'};">
                  ${hasSpecial ? '✓' : '✗'} One special character (!@#$%^&*)
                </div>
              </div>
            `,
            icon: 'warning',
            confirmButtonColor: '#007bff'
          });
          return false;
        }

        // Confirm Password validation
        if (password !== confirmPassword) {
          await Swal.fire({
            title: '<span style="font-size: 24px; font-weight: 600;">Passwords Don\'t Match</span>',
            text: 'Please ensure both passwords are identical',
            icon: 'error',
            confirmButtonColor: '#007bff'
          });
          return false;
        }

        try {
          const form = event.target;
          const formData = new FormData(form);
          const response = await fetch(form.action, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify(Object.fromEntries(formData))
          });

          const data = await response.json();

          if (data.success) {
            await Swal.fire({
              title: '<span style="font-size: 24px; font-weight: 600;">Success!</span>',
              text: data.message || 'Registration successful! Please verify your email.',
              icon: 'success',
              confirmButtonColor: '#007bff'
            });
            window.location.href = data.redirectUrl || '/verify-otp';
          } else {
            await Swal.fire({
              title: '<span style="font-size: 24px; font-weight: 600;">Error</span>',
              text: data.message || 'Registration failed. Please try again.',
              icon: 'error',
              confirmButtonColor: '#007bff'
            });
          }
        } catch (error) {
          await Swal.fire({
            title: '<span style="font-size: 24px; font-weight: 600;">Error</span>',
            text: 'An error occurred during registration. Please try again.',
            icon: 'error',
            confirmButtonColor: '#007bff'
          });
        }

        return false;
      }
    </script>

    <!-- Bootstrap JS and dependencies for dynamic components -->
    <script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.5.0/dist/umd/popper.min.js"></script>
    <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>
  </body>
</html>
