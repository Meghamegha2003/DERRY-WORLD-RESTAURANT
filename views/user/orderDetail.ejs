<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Order Details</title>
    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" />
    <style>
      .order-summary {
        background: #f8f9fa;
        padding: 20px;
        border-radius: 10px;
        margin-top: 20px;
      }
      .table th,
      .table td {
        vertical-align: middle;
      }
      .order-status {
        font-weight: bold;
        color: #ffc107;
      }
    </style>
  </head>
  <body>
    <div class="container mt-5">
      <h2 class="text-center">Latest Order Details</h2>
      
      <% if (orders && orders.length > 0) { 
        const order = orders[0]; %>  <!-- Use the first (latest) order -->
        
        <!-- Order Header -->
        <div class="text-center mb-4">
          <h3>Order ID: <%= order._id %></h3>
          <p class="text-muted">Order placed on: <%= order.createdAt.toDateString() %></p>
        </div>

        <!-- Order Summary -->
        <div class="order-summary">
          <h5>Order Summary</h5>
          <p><strong>Status:</strong> <span class="order-status"><%= order.status || "Pending" %></span></p>
          <p><strong>Total Amount:</strong> ₹<%= order.totalAmount %></p>
        </div>

        <!-- Order Items -->
        <div class="mt-4">
          <h5>Items</h5>
          <table class="table table-bordered">
            <thead class="thead-light">
              <tr>
                <th>Item</th>
                <th>Quantity</th>
                <th>Price</th>
                <th>Total</th>
              </tr>
            </thead>
            <tbody>
              <% order.items.forEach(item => { %>
                <tr>
                  <td>
                    <!-- Check if item.product exists and then check productImage -->
                    <% if (item.product && item.product.productImage && item.product.productImage[0]) { %>
                      <img src="/<%= item.product.productImage[0] %>" alt="<%= item.product.name %>" style="width: 50px; height: 50px; border-radius: 5px; margin-right: 10px;" />
                    <% } else { %>
                      <img src="/default-image.jpg" alt="Default Image" style="width: 50px; height: 50px; border-radius: 5px; margin-right: 10px;" />
                    <% } %>
                    
                    <%= item.product ? item.product.name : 'Unknown Product' %>
                  </td>
                  <td><%= item.quantity %></td>
                  <td>₹<%= item.price %></td>
                  <td>₹<%= item.price * item.quantity %></td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>

        <!-- Delivery Details -->
        <div class="mt-4">
          <h5>Delivery Address</h5>
          <p>
            <strong>Street:</strong> <%= order.address.street %><br>
            <strong>City:</strong> <%= order.address.city %><br>
            <strong>State:</strong> <%= order.address.state %><br>
            <strong>Postal Code:</strong> <%= order.address.zipCode %>
          </p>
        </div>

        <hr>
      <% } else { %>
        <p>No orders found.</p>
      <% } %>

      <!-- Back to Orders Button -->
      <div class="text-center mt-4">
        <a href="/order/{{orderId}}" class="btn btn-primary">Back to Orders</a>
      </div>
    </div>
  
    <!-- Bootstrap JS -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://maxcdn.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>
  </body>
</html>
