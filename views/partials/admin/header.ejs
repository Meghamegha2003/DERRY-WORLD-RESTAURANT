<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Responsive Admin Dashboard</title>
  <!-- Bootstrap CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/css/bootstrap.min.css" rel="stylesheet">
  <!-- Bootstrap Icons -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.10.5/font/bootstrap-icons.min.css">
  <!-- Google Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
  <style>
    body {
      font-family: 'Roboto', sans-serif;
    }

    /* Navbar Styling */
    .navbar {
      background-color: #fff;
      box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    }

    /* Make the logo bigger */
    .navbar-brand {
      font-weight: bold;
      color: #2c2c2c;
      font-size: 2rem;  /* Increase font size of the logo */
    }

    .navbar .form-control {
      border: 1px solid #ffc107;
      width: 300px; /* Set the width of the search bar */
    }

    /* Align the search bar in the center */
    .navbar .ms-auto {
      display: flex;
      justify-content: center; /* Center the search bar */
      align-items: center;
      flex: 1; /* Ensure it takes available space */
    }

    /* Right-aligned admin and logout */
    .navbar .right-align {
      display: flex;
      align-items: center;
    }

    .navbar .right-align .me-3 {
      margin-right: 10px;
    }

    /* Sidebar Styling */
    .sidebar {
      height: 100vh;
      background-color: #fff;
      border-right: 1px solid #ddd;
      position: sticky;
      top: 0;
      transition: all 0.3s ease-in-out;
      box-shadow: 4px 0 6px rgba(0, 0, 0, 0.1);  /* Add box shadow */
    }

    .sidebar .nav-link {
      color: #6c757d;
      padding: 10px;
      font-size: 1rem;
      font-weight: 500;
    }

    .sidebar .nav-link i {
      color: #ffc107;
    }

    .sidebar .nav-link:hover {
      background-color: #8B4513;
      color: #fff;
    }

    .sidebar .nav-link.active {
      background-color: #8B4513;
      color: #fff;
    }

    .sidebar.collapsed {
      transform: translateX(-100%);
    }

    /* Main Content Styling */
    main {
      padding: 1rem;
      background-color: #f8f9fa;
      min-height: 100vh;
      margin-left: 250px;  /* Space between sidebar and content */
    }

    /* Sidebar Toggle for Mobile */
    @media (max-width: 768px) {
      .sidebar {
        position: fixed;
        left: 0;
        top: 0;
        z-index: 1050;
        width: 250px;
        transform: translateX(-100%);
      }

      .sidebar.active {
        transform: translateX(0);
      }

      main {
        margin-left: 0;  /* Remove space on mobile */
      }
    }

    /* Close button inside the sidebar for mobile */
    .close-sidebar {
      position: absolute;
      top: 10px;
      right: 10px;
      font-size: 1.5rem;
      color: #8B4513;
      background: none;
      border: none;
      cursor: pointer;
    }

  </style>
</head>
<body>
  <!-- Navbar -->
  <nav class="navbar navbar-expand-lg navbar-light">
    <div class="container-fluid">
      <button class="btn btn-outline-dark d-md-none me-3" id="sidebarToggle">
        <i class="bi bi-list"></i>
      </button>
      <a class="navbar-brand" href="#">Derry World</a>
      <div class="collapse navbar-collapse">
        <div class="ms-auto">
          <input type="text" class="form-control me-2" placeholder="Search">
        </div>
        <div class="right-align ms-3">
          <span class="me-3"><i class="bi bi-person"></i> Admin</span>
          <a href="/admin/logout" class="btn btn-link" style="text-decoration: none;"><i class="bi bi-box-arrow-right"></i></a>
        </div>
      </div>
    </div>
  </nav>

  <div class="container-fluid">
    <div class="row">
      <!-- Sidebar -->
      <nav class="col-md-2 d-md-block sidebar" id="sidebar">
        <!-- Close Button for Mobile -->
        <button class="close-sidebar" id="closeSidebarBtn">
          <i class="bi bi-x"></i>
        </button>
        <ul class="nav flex-column mt-3">
          <li class="nav-item">
            <a class="nav-link" href="/admin/dashboard">
              <i class="bi bi-grid"></i> Dashboard
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/admin/customer-list">
              <i class="bi bi-people"></i> Customers
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/admin/categories">
              <i class="bi bi-tags"></i> Categories
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/admin/products">
              <i class="bi bi-box"></i> Products
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/admin/orders">
              <i class="bi bi-cart"></i> Orders
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="#">
              <i class="bi bi-percent"></i> Coupons
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="#">
              <i class="bi bi-wallet"></i> Payments
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="#">
              <i class="bi bi-gift"></i> Offers
            </a>
          </li>
        </ul>
        
        <script>
        // Get all the nav links inside the sidebar
        const navLinks = document.querySelectorAll('.sidebar .nav-link');
        
        // Get the current URL path
        const currentPath = window.location.pathname;
        
        // Loop through all the nav links
        navLinks.forEach(link => {
          // Check if the href matches the current URL
          if (link.getAttribute('href') === currentPath) {
            // Add the 'active' class to the matching link
            link.classList.add('active');
          } else {
            // Remove the 'active' class from non-matching links
            link.classList.remove('active');
          }
        });
        </script>
        
      </nav>
    