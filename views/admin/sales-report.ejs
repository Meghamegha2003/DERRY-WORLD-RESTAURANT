<%- include('../partials/admin/header') %>

<!-- Main Content -->
<main class="col-md-10 ms-sm-auto col-lg-10 px-md-4 py-4">
  <h1 class="h3 mb-4">Sales Report</h1>
  
  <!-- Filter Section -->
  <div class="card mb-4">
    <div class="card-body">
      <form id="filterForm" action="/admin/sales-report" method="GET" class="row g-3">
        <div class="col-md-3">
          <label for="startDate" class="form-label">From Date</label>
          <input type="date" class="form-control" id="startDate" name="startDate" value="<%= locals.startDate || '' %>">
        </div>
        <div class="col-md-3">
          <label for="endDate" class="form-label">To Date</label>
          <input type="date" class="form-control" id="endDate" name="endDate" value="<%= locals.endDate || '' %>">
        </div>
        <div class="col-md-4">
          <label for="searchQuery" class="form-label">Search Orders</label>
          <input type="text" class="form-control" id="searchQuery" name="searchQuery" 
                 placeholder="Search by order #, customer, product..." value="<%= locals.searchQuery || '' %>">
        </div>
        <div class="col-md-2 d-flex align-items-end">
          <button type="submit" class="btn btn-primary me-2">Filter</button>
          <a href="/admin/sales-report" class="btn btn-outline-secondary">Reset</a>
        </div>
      </form>
    </div>
  </div>
  
  <!-- Orders Table -->
  <div class="card border-0 shadow-sm">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-dark">
            <tr>
              <th scope="col" style="width: 120px;">ORDER #</th>
              <th scope="col" style="width: 120px;">DATE</th>
              <th scope="col" style="width: 200px;">CUSTOMER</th>
              <th scope="col" class="text-center">ITEMS</th>
              <th scope="col" class="text-end" style="width: 150px;">TOTAL</th>
            </tr>
          </thead>
          <tbody>
            <% if (orders && orders.length > 0) { 
                // Create a flattened array of all items with their order info
                const allItems = [];
                orders.forEach(order => {
                  if (order.items && order.items.length > 0) {
                    order.items.forEach(item => {
                      allItems.push({
                        ...item,
                        orderId: order._id,
                        orderNumber: order.orderNumber,
                        orderDate: order.createdAt,
                        user: order.user,
                        paymentMethod: order.paymentMethod,
                        orderStatus: order.orderStatus,
                        appliedCoupon: order.appliedCoupon,
                        itemCouponDiscount: item.itemCouponDiscount || 0,
                        _order: order // Keep reference to the full order object
                      });
                    });
                  }
                });
                
                // Now render all items
                allItems.forEach(item => {
                  const order = item._order;
                  const formattedOrderId = order && order._id ? order._id.toString().slice(-6).toUpperCase() : 'N/A';
            %>
                <tr>
                  <td class="align-middle">
                    <div class="fw-semibold">
                      <i class="fas fa-hashtag me-1 text-muted"></i>
                      <a href="/admin/orders/<%= order._id || '' %>" class="text-decoration-none">
                        #<%= order._id ? order._id.toString().slice(-6).toUpperCase() : 'N/A' %>
                      </a>
                    </div>
                  </td>
                  <td class="align-middle">
                    <div class="small text-muted">
                      <%= order.createdAt ? new Date(order.createdAt).toLocaleDateString('en-US', { 
                        year: 'numeric', 
                        month: 'short', 
                        day: 'numeric',
                        hour: '2-digit',
                        minute: '2-digit'
                      }) : 'N/A' %>
                    </div>
                  </td>
                  <td class="align-middle">
                    <div class="d-flex align-items-center">
                      <div class="ms-2">
                        <% if (order.user && (order.user.name || order.user.email)) { %>
                          <% if (order.user.name) { %>
                            <div class="fw-medium"><%= order.user.name %></div>
                          <% } %>
                          <% if (order.user.email) { %>
                            <div class="text-muted small"><%= order.user.email %></div>
                          <% } %>
                        <% } else { %>
                          <div class="fw-medium">Guest</div>
                        <% } %>
                      </div>
                    </div>
                  </td>
                  <td class="align-middle">
                    <div class="d-flex align-items-center">
                      <div class="ms-2">
                        <div class="fw-medium"><%= item.quantity %> × <%= item.product ? item.product.name : 'Product' %></div>
                        <div class="text-muted small">
                          <% const itemPrice = item.price * item.quantity; %>
                          <%= typeof formatCurrency === 'function' ? formatCurrency(item.price) : '₹' + item.price.toFixed(2) %> each
                        </div>
                        <% if (item.itemCouponDiscount > 0) { %>
                          <div class="mt-1">
                            <span class="badge bg-success text-white">
                              <i class="fas fa-tag me-1"></i>
                              <% if (item.appliedCoupon && item.appliedCoupon.code) { %>
                                <%= item.appliedCoupon.code %>
                              <% } else { %>
                                Coupon Applied
                              <% } %>
                              -<%= typeof formatCurrency === 'function' ? formatCurrency(item.itemCouponDiscount) : '₹' + item.itemCouponDiscount.toFixed(2) %>
                              <% if (item.appliedCoupon && item.appliedCoupon.discountType === 'percentage') { %>
                                (<%= item.appliedCoupon.discountValue %>%)
                              <% } %>
                            </span>
                          </div>
                        <% } %>
                      </div>
                    </div>
                  </td>
                  <td class="align-middle text-end">
                    <div class="fw-bold">
                      <% 
                        const itemSubtotal = item.price * item.quantity;
                        const itemTotal = itemSubtotal - (item.itemCouponDiscount || 0);
                      %>
                      <% if (item.itemCouponDiscount > 0) { %>
                        <div class="text-decoration-line-through text-muted small">
                          <%= typeof formatCurrency === 'function' ? formatCurrency(itemSubtotal) : '₹' + itemSubtotal.toFixed(2) %>
                        </div>
                      <% } %>
                      <div class="<%= item.itemCouponDiscount > 0 ? 'text-danger' : '' %>">
                        <%= typeof formatCurrency === 'function' ? formatCurrency(itemTotal) : '₹' + itemTotal.toFixed(2) %>
                      </div>
                    </div>
                    <div class="small text-muted">
                      <span class="badge bg-success">
                        <i class="fas fa-check-circle me-1"></i> Delivered
                      </span>
                    </div>
                  </td>
                </tr>
              <% }); %>
            <% } else { %>
              <tr>
                <td colspan="5" class="text-center p-5">
                  <div class="no-results">
                    <i class="bi bi-receipt" style="font-size: 3.5rem; opacity: 0.2;"></i>
                    <h5 class="mt-3 mb-2">No orders found</h5>
                    <p class="text-muted">Try adjusting your filters or check back later for new orders.</p>
                  </div>
                </td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
    
    <!-- Pagination -->
    <% if (totalPages > 1) { %>
      <div class="card-footer bg-white border-top-0">
        <nav aria-label="Orders pagination">
          <ul class="pagination justify-content-center mb-0">
            <!-- First Page -->
            <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
              <a class="page-link" href="<%= buildPaginationUrl(1) %>" aria-label="First">
                <span aria-hidden="true">&laquo;&laquo;</span>
              </a>
            </li>
            
            <!-- Previous Page -->
            <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
              <a class="page-link" href="<%= buildPaginationUrl(currentPage - 1) %>" aria-label="Previous">
                <span aria-hidden="true">&laquo;</span>
              </a>
            </li>
            
            <!-- Page Numbers -->
            <% for (let i = 1; i <= totalPages; i++) { %>
              <% if (i === 1 || i === totalPages || (i >= currentPage - 2 && i <= currentPage + 2)) { %>
                <li class="page-item <%= i === currentPage ? 'active' : '' %>">
                  <a class="page-link" href="<%= buildPaginationUrl(i) %>"><%= i %></a>
                </li>
              <% } else if (i === currentPage - 3 || i === currentPage + 3) { %>
                <li class="page-item disabled">
                  <span class="page-link">...</span>
                </li>
              <% } %>
            <% } %>
            
            <!-- Next Page -->
            <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
              <a class="page-link" href="<%= buildPaginationUrl(currentPage + 1) %>" aria-label="Next">
                <span aria-hidden="true">&raquo;</span>
              </a>
            </li>
            
            <!-- Last Page -->
            <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
              <a class="page-link" href="<%= buildPaginationUrl(totalPages) %>" aria-label="Last">
                <span aria-hidden="true">&raquo;&raquo;</span>
              </a>
            </li>
          </ul>
        </nav>
      </div>
    <% } %>
  </div>
</main>

<!-- JavaScript -->
<script>
document.addEventListener('DOMContentLoaded', function() {
  // Initialize date pickers with default dates and validation
  const today = new Date();
  const startDateInput = document.querySelector('input[name="startDate"]');
  const endDateInput = document.querySelector('input[name="endDate"]');
  const filterForm = document.getElementById('filterForm');

  // Format date as YYYY-MM-DD
  const formatDate = (date) => {
    const d = new Date(date);
    let month = '' + (d.getMonth() + 1);
    let day = '' + d.getDate();
    const year = d.getFullYear();

    if (month.length < 2) month = '0' + month;
    if (day.length < 2) day = '0' + day;

    return [year, month, day].join('-');
  };

  // Set max date to today for both date inputs
  if (startDateInput) startDateInput.max = formatDate(today);
  if (endDateInput) endDateInput.max = formatDate(today);

  // Validate date range
  if (startDateInput && endDateInput) {
    startDateInput.addEventListener('change', function() {
      if (endDateInput.value && new Date(this.value) > new Date(endDateInput.value)) {
        endDateInput.value = this.value;
      }
    });

    endDateInput.addEventListener('change', function() {
      if (startDateInput.value && new Date(this.value) < new Date(startDateInput.value)) {
        startDateInput.value = this.value;
      }
    });
  }
});

// Helper function to build pagination URLs with existing query parameters
function buildPaginationUrl(page) {
  const url = new URL(window.location.href);
  url.searchParams.set('page', page);
  return url.pathname + url.search;
}

// Handle export to CSV
function exportToCSV() {
  const url = new URL(window.location.href);
  url.searchParams.set('export', 'csv');
  window.location.href = url.toString();
}

// Add event listener for export button
document.addEventListener('DOMContentLoaded', function() {
  const exportBtn = document.getElementById('exportCSV');
  if (exportBtn) {
    exportBtn.addEventListener('click', exportToCSV);
  }
});
</script>

<%- include('../partials/admin/footer') %>
